# Copy this file to .env.local and update the value if needed.
# Default points to the local backend dev server.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
BACKEND_INTERNAL_URL=http://127.0.0.1:3001

# Server-only — used by Next.js route handlers to proxy MP-gated FastAPI calls.
# Must match MP_API_SECRET in backend/.env. Never use a NEXT_PUBLIC_ prefix.
BACKEND_URL=http://127.0.0.1:3001
MP_API_SECRET=change-me-to-a-long-random-string

# Google Maps JavaScript API (Maps + Visualization library for insights heatmap)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase client SDK (public keys — same project as backend/.env)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin — server-only, for allowlist checks (reuse backend service account)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=../backend/secrets/firebase-adminsdk.json

# Signed session cookie secret (generate a long random string)
MP_SESSION_SECRET=change-me-to-a-long-random-string
