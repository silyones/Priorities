PORT=3001
FRONTEND_ORIGIN=http://localhost:3000
MP_FRONTEND_ORIGIN=http://localhost:3002

SARVAM_API_KEY=your_sarvam_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Admin — required for backend Firestore access after rules lockdown.
# Path to a service-account JSON file, OR inline JSON via FIREBASE_SERVICE_ACCOUNT_JSON.
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/serviceAccountKey.json

# MP-only API guard — required for subscriber list + status PATCH on FastAPI.
# Same value must be set as MP_API_SECRET in frontend/.env.local (Next.js server proxy).
MP_API_SECRET=change-me-to-a-long-random-string
