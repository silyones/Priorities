rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // All Firestore access goes through the backend (Firebase Admin SDK).
    // Citizen and MP frontends use REST APIs — no direct client reads/writes.
    match /submissions/{submissionId} {
      allow read, write: if false;
    }

    match /issues/{issueId} {
      allow read, write: if false;

      match /subscribers/{phoneNumber} {
        allow read, write: if false;
      }
    }
  }
}
